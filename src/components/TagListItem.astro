---
import CollapsePanel from "./CollapsePanel.astro";
import TagPostListItem from "./TagPostListItem.astro";

interface PostEntry {
    id: string;
    data: {
        title: string;
        date: Date;
        tags: string[];
    };
}

interface Props {
    index: number;
    name: string;
    posts: PostEntry[];
}

const { index, name, posts } = Astro.props;
---

<li class="list-none">
    <CollapsePanel accordion={true}>
        <Fragment slot="title">
            <div class="flex items-center gap-4">
                <div class="text-sm tabular-nums opacity-50">
                    {String(index + 1).padStart(2, "0")}
                </div>
                <div class="min-w-0 flex-1">
                    <div class="truncate text-xl font-medium tabular-nums">
                        {name}
                    </div>
                    <div
                        class="text-xs font-semibold tracking-wide uppercase opacity-60"
                    >
                        {posts.length} posts
                    </div>
                </div>
            </div>
        </Fragment>
        {
            posts.length > 0 ? (
                <ul class="flex flex-col gap-2 py-3">
                    {posts.map((post) => (
                        <TagPostListItem
                            title={post.data.title}
                            date={post.data.date}
                            href={`/posts/${post.id}/`}
                        />
                    ))}
                </ul>
            ) : (
                <p class="py-4 text-sm opacity-70">
                    This tag has no posts yet.
                </p>
            )
        }
    </CollapsePanel>
</li>
