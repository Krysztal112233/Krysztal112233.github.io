---
import { Icon } from "astro-icon/components";
---

<li>
    <label class="btn btn-ghost swap swap-rotate" aria-label="切换主题">
        <input class="theme-toggle" type="checkbox" />
        <div class="swap-off text-2xl">
            <Icon name="material-symbols:sunny-outline" />
        </div>
        <div class="swap-on text-2xl">
            <Icon name="material-symbols:moon-stars-outline" />
        </div>
    </label>
</li>
