---
import { Icon } from "astro-icon/components";

interface Props {
    date: Date | string;
    href: string;
    title: string;
}

const { date, href, title } = Astro.props;
const publishedAt = new Date(date);
---

<li>
    <a
        href={href}
        class="hover:bg-base-100 flex items-start justify-between gap-4 rounded-xl px-3 py-3 transition-colors"
    >
        <div class="min-w-0 flex-1">
            <div class="line-clamp-2 text-base font-medium">
                {title}
            </div>
            <div
                class="mt-2 flex flex-wrap items-center gap-3 text-xs opacity-70"
            >
                <span class="inline-flex items-center gap-1">
                    <Icon
                        name="material-symbols:date-range-outline"
                        size="14px"
                    />
                    <time>{publishedAt.toDateString()}</time>
                </span>
            </div>
        </div>
    </a>
</li>
