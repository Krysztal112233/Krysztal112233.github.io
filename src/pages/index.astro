---
import { getCollection } from "astro:content";
import HomePostListPage from "../components/HomePostListPage.astro";
import MainFrame from "../layout/MainFrame.astro";
import { getPaginatedPosts, sortPosts } from "../utils/postPagination";

const allPosts = await getCollection("posts");
sortPosts(allPosts);

const { posts, currentPage, totalPages } = getPaginatedPosts(allPosts, 1);
---

<MainFrame>
    <HomePostListPage
        posts={posts}
        currentPage={currentPage}
        totalPages={totalPages}
    />
</MainFrame>
