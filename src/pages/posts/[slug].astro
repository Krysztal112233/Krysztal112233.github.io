---
import { getCollection, render } from "astro:content";
import PostPage from "../../layout/PostPage.astro";
import TagBadgeList from "../../components/TagBadgeList.astro";
import { getPostSummary } from "../../utils/postSummary";

export async function getStaticPaths() {
    const posts = await getCollection("posts");
    return posts.map((post) => ({
        params: { slug: post.id },
        props: { post },
    }));
}

const { post } = Astro.props as any;
const { Content, headings } = (await render(post)) as any;
const summary = getPostSummary(post);
---

<PostPage
    subtitle={post.data.title}
    description={summary}
    headings={headings}
>
    <div class="pt-4">
        <h1 class="mb-4 text-3xl font-bold">{post.data.title}</h1>
        <div class="text-gray-500">
            <time
                class="italic"
                style="font-family: Victor Mono; font-display: swap;"
                >{post.data.date.toDateString()}</time
            >
            {
                post.data.tags && post.data.tags.length > 0 && (
                    <div class="mt-2">
                        <TagBadgeList tags={post.data.tags} />
                    </div>
                )
            }
        </div>

        <div class="divider m-1"></div>

        <Content />
    </div>
</PostPage>
