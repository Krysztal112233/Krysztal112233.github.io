---
import { getCollection, type CollectionEntry } from "astro:content";
import HomePostListPage from "../../components/HomePostListPage.astro";
import MainFrame from "../../layout/MainFrame.astro";
import { getPaginatedPosts, sortPosts } from "../../utils/postPagination";

export async function getStaticPaths() {
    const allPosts = await getCollection("posts");
    sortPosts(allPosts);

    const { totalPages } = getPaginatedPosts(allPosts, 1);

    return Array.from({ length: Math.max(totalPages - 1, 0) }, (_, index) => {
        const currentPage = index + 2;
        const { posts } = getPaginatedPosts(allPosts, currentPage);

        return {
            params: { page: currentPage.toString() },
            props: {
                posts,
                currentPage,
                totalPages,
            },
        };
    });
}

interface Props {
    posts: CollectionEntry<"posts">[];
    currentPage: number;
    totalPages: number;
}

const { posts, currentPage, totalPages }: Props = Astro.props;
---

<MainFrame>
    <HomePostListPage
        posts={posts}
        currentPage={currentPage}
        totalPages={totalPages}
    />
</MainFrame>
